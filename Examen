#include <iostream>
#include <string>

using namespace std;

class Billetera {
private:
    string propietario;
    double saldo;
    double gastos[20];
    int cantidad;

public:
    Billetera(string nombre, double s) {
        propietario = nombre;
        saldo = s;
        cantidad = 0;
    }

    void agregarIngreso(double monto) {
        if (monto > 0) {
            saldo = saldo + monto;
        }
    }

    void registrarGasto(double monto, int& contadorSesion) {
        if (monto <= 0) {
            cout << "Error: monto invalido" << endl;
        } else if (monto > saldo) {
            cout << "Error: saldo insuficiente" << endl;
        } else if (cantidad >= 20) {
            cout << "Historial lleno" << endl;
        } else {
            saldo = saldo - monto;
            gastos[cantidad] = monto;
            cantidad++;
            contadorSesion++;
            cout << "Gasto registrado. Saldo: $" << saldo << endl;
        }
    }

    void mostrarHistorial() {
        cout << "=== HISTORIAL ===" << endl;
        for (int i = 0; i < cantidad; i++) {
            cout << "Gasto " << i + 1 << ": $" << gastos[i] << endl;
        }
    }

    void mostrarEstado() {
        cout << "Propietario: " << propietario << endl;
        cout << "Saldo: $" << saldo << endl;
        cout << "Gastos: " << cantidad << endl;
    }

    double calcularPromedio() {
        if (cantidad == 0) {
            return 0;
        }

        double suma = 0;
        for (int i = 0; i < cantidad; i++) {
            suma = suma + gastos[i];
        }

        return suma / cantidad;
    }

    double* getSaldoPtr() {
        return &saldo;
    }
};

void aplicarCargo(double* ptrSaldo) {
    *ptrSaldo = *ptrSaldo - 5;

    if (*ptrSaldo < 0) {
        *ptrSaldo = 0;
    }

    cout << "Cargo aplicado: -$5" << endl;
}

int main() {
    string nombre;
    double saldoInicial;
    int opcion;
    int gastosSesion = 0;

    cout << "Propietario: ";
    cin >> nombre;

    cout << "Saldo inicial: ";
    cin >> saldoInicial;

    Billetera b(nombre, saldoInicial);

    while (true) {
        cout << endl;
        cout << "=== MENU ===" << endl;
        cout << "1. Agregar ingreso" << endl;
        cout << "2. Registrar gasto" << endl;
        cout << "3. Ver historial" << endl;
        cout << "4. Ver estado" << endl;
        cout << "5. Ver promedio" << endl;
        cout << "6. Aplicar cargo" << endl;
        cout << "7. Salir" << endl;
        cout << "Opcion: ";
        cin >> opcion;

        if (opcion == 1) {
            double m;
            cin >> m;
            b.agregarIngreso(m);
        } else if (opcion == 2) {
            double m;
            cin >> m;
            b.registrarGasto(m, gastosSesion);
        } else if (opcion == 3) {
            b.mostrarHistorial();
        } else if (opcion == 4) {
            b.mostrarEstado();
        } else if (opcion == 5) {
            cout << "Promedio: $" << b.calcularPromedio() << endl;
        } else if (opcion == 6) {
            aplicarCargo(b.getSaldoPtr());
        } else if (opcion == 7) {
            cout << "Sesion terminada. Gastos registrados: " << gastosSesion << endl;
            break;
        }
    }

    return 0;
}
